{
  "kind": "singleType",
  "collectionName": "vapt_pages",
  "info": {
    "singularName": "vapt-page",
    "pluralName": "vapt-pages",
    "displayName": "VAPT Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "ds.seo-meta"
    },
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "string"
    },
    "heroDescription": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "heroCtaPrimary": {
      "type": "component",
      "repeatable": false,
      "component": "ds.cta-link"
    },
    "heroCtaSecondary": {
      "type": "component",
      "repeatable": false,
      "component": "ds.cta-link"
    },
    "pillars": {
      "type": "component",
      "repeatable": true,
      "component": "ds.icon-card"
    },
    "pricingLabel": {
      "type": "string"
    },
    "pricingTitle": {
      "type": "string"
    },
    "pricingDesc": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "pricingPlans": {
      "type": "component",
      "repeatable": true,
      "component": "ds.pricing-plan"
    },
    "whyLabel": {
      "type": "string"
    },
    "whyTitle": {
      "type": "string"
    },
    "whyCards": {
      "type": "component",
      "repeatable": true,
      "component": "ds.icon-card"
    },
    "whatTitle": {
      "type": "string"
    },
    "whatDesc": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "whatLayers": {
      "type": "json"
    },
    "whatClosing": {
      "type": "text"
    },
    "whyChooseLabel": {
      "type": "string"
    },
    "whyChooseTitle": {
      "type": "string"
    },
    "whyChooseCards": {
      "type": "component",
      "repeatable": true,
      "component": "ds.icon-card"
    },
    "ctaBand1": {
      "type": "component",
      "repeatable": false,
      "component": "ds.cta-band"
    },
    "offeringsLabel": {
      "type": "string"
    },
    "offeringsTitle": {
      "type": "string"
    },
    "offeringsSubtitle": {
      "type": "text"
    },
    "offeringsCards": {
      "type": "component",
      "repeatable": true,
      "component": "ds.icon-card"
    },
    "processLabel": {
      "type": "string"
    },
    "processTitle": {
      "type": "string"
    },
    "processSubtitle": {
      "type": "text"
    },
    "steps": {
      "type": "component",
      "repeatable": true,
      "component": "ds.numbered-tip"
    },
    "whenLabel": {
      "type": "string"
    },
    "whenTitle": {
      "type": "string"
    },
    "whenSubtitle": {
      "type": "text"
    },
    "whenPoints": {
      "type": "component",
      "repeatable": true,
      "component": "ds.numbered-tip"
    },
    "whenClosing": {
      "type": "text"
    },
    "testimonialTitle": {
      "type": "string"
    },
    "testimonials": {
      "type": "component",
      "repeatable": true,
      "component": "ds.testimonial-card"
    },
    "faqTitle": {
      "type": "string"
    },
    "faq": {
      "type": "component",
      "repeatable": true,
      "component": "ds.faq-entry"
    },
    "ctaBand2": {
      "type": "component",
      "repeatable": false,
      "component": "ds.cta-band"
    },
    "heroFormEnabled": {
      "type": "boolean",
      "default": false
    },
    "heroImage": {
      "type": "component",
      "component": "common.image",
      "repeatable": false
    }
  }
}
