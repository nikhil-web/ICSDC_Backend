{
  "kind": "collectionType",
  "collectionName": "builder_pages",
  "info": {
    "singularName": "builder-page",
    "pluralName": "builder-pages",
    "displayName": "Builder Page",
    "description": "Pages created with the visual page builder"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "sections": {
      "type": "json",
      "required": true,
      "default": []
    },
    "metaTitle": {
      "type": "string",
      "maxLength": 255
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 500
    },
    "templateId": {
      "type": "string",
      "maxLength": 100
    },
    "publishedVersion": {
      "type": "integer",
      "default": 0
    },
    "currentVersion": {
      "type": "integer",
      "default": 1
    }
  }
}
