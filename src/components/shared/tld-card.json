{
  "collectionName": "components_shared_tld_cards",
  "info": {
    "displayName": "TLD Card",
    "description": "Domain TLD extension with price and badge",
    "icon": "earth"
  },
  "attributes": {
    "extension": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "string",
      "required": true
    },
    "originalPrice": {
      "type": "string"
    },
    "description": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "badge": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
