{
  "collectionName": "components_shared_solution_cards",
  "info": {
    "displayName": "Solution Card",
    "description": "Product/solution card with icon, description, tagline and CTA",
    "icon": "apps"
  },
  "attributes": {
    "icon": {
      "type": "string",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "tagline": {
      "type": "string"
    },
    "ctaText": {
      "type": "string"
    },
    "ctaStyle": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
