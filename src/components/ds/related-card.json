{
  "collectionName": "components_ds_related_cards",
  "info": {
    "displayName": "DS Related Card",
    "description": "Related service card with title, description, and a CTA link"
  },
  "attributes": {
    "order": {
      "type": "integer",
      "default": 0
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "btnLabel": {
      "type": "string"
    },
    "btnUrl": {
      "type": "string"
    }
  }
}
