{
  "collectionName": "components_ds_icon_cards",
  "info": {
    "displayName": "DS Icon Card",
    "description": "Reusable icon + title + description card. Icon is a key name resolved on frontend via ICONS map."
  },
  "attributes": {
    "icon": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "desc": {
      "type": "text",
      "required": false
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "link": {
      "type": "string",
      "required": false
    }
  }
}
