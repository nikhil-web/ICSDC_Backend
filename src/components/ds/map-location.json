{
  "collectionName": "components_ds_map_locations",
  "info": {
    "displayName": "DS Map Location",
    "description": "A country/region pin on the world map. Pick a countryKey from the dropdown — coordinates are automatically resolved in the frontend MAP_COORDS table."
  },
  "attributes": {
    "order": {
      "type": "integer",
      "default": 0
    },
    "title": {
      "type": "string",
      "required": true
    },
    "countryKey": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "usa",
        "uk",
        "germany",
        "russia",
        "india",
        "future-expansion"
      ]
    },
    "description": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "pinColor": {
      "type": "string",
      "default": "#1a56db"
    }
  }
}
