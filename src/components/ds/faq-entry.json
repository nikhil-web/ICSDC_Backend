{
  "collectionName": "components_ds_faq_entries",
  "info": {
    "displayName": "DS FAQ Entry",
    "description": "FAQ question and answer pair"
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true
    },
    "answer": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
