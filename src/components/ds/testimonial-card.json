{
  "collectionName": "components_ds_testimonial_cards",
  "info": {
    "displayName": "DS Testimonial Card",
    "description": "Client testimonial with name, title, company, quote, and rating"
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "quote": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "rating": {
      "type": "integer",
      "default": 5
    },
    "Avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
