{
  "collectionName": "components_sections_footers",
  "info": {
    "displayName": "Footer",
    "icon": "grid",
    "description": "Full footer content including address, socials and link columns"
  },
  "attributes": {
    "address": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "linkGroups": {
      "type": "component",
      "component": "shared.footer-link-group",
      "repeatable": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
