{
  "collectionName": "components_sections_text_images",
  "info": {
    "displayName": "Text + Image",
    "icon": "landscape",
    "description": "Reusable two-column text + image section (Less Complexity, Industry Validated)"
  },
  "attributes": {
    "heading": {
      "type": "string"
    },
    "paragraph": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
